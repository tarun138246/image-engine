# Pratima Image Engine — environment template
# Copy this file to .env and fill in every value before starting the server.

# Port the Node.js process listens on (bind address is controlled by HOST)
PORT=3001

# Bind address — use 127.0.0.1 (default) when nginx proxies; 0.0.0.0 for direct access
HOST=127.0.0.1

# Secret used to authenticate upload and management API calls (x-api-key header)
API_KEY=replace-with-a-strong-random-string

# 32-byte AES-256 key encoded as 64 hex characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: changing this key makes all previously stored images unreadable.
ENCRYPTION_KEY=replace-with-64-hex-chars

# Unix socket path for the ClamAV daemon (optional — omit or leave default)
CLAMD_SOCKET=/var/run/clamav/clamd.ctl

# Maximum accepted upload size in bytes (default 10 MB)
MAX_FILE_SIZE=10485760

# WebP conversion quality 1-100 (default 92)
WEBP_QUALITY=92

# Maximum simultaneous upload processing slots (default 2)
CONCURRENCY_LIMIT=2

# Absolute path on disk where encrypted images are stored
STORAGE_PATH=/var/pratima

# Redis connection URL — include password if auth is enabled
REDIS_URL=redis://:yourpassword@127.0.0.1:6379

# Public-facing base URL used to build image URLs returned by /upload
# Must not end with a trailing slash
PUBLIC_URL=https://yourdomain.com
